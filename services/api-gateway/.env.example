# Local development ONLY — never enable on production Vercel/hosts.
# Production API traffic uses apps/web/src/app/api/* (Next.js).

# Required to accept any request (otherwise every route returns 503).
TRIMMA_API_GATEWAY_ENABLED=true

# Supabase (service role is used by this scaffold — keep local only).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional: restrict browser CORS (defaults to http://localhost:3000).
TRIMMA_API_GATEWAY_CORS_ORIGIN=http://localhost:3000

PORT=4000
