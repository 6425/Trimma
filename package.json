{
  "name": "trimma-monorepo",
  "private": true,
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@trimma/web",
    "dev:restart": "npm run dev:restart --workspace=@trimma/web",
    "dev:gateway": "node -e \"require('child_process').spawn('npm', ['run','start:dev','--workspace=@trimma/api-gateway'], {stdio:'inherit', shell:true, env:{...process.env, TRIMMA_API_GATEWAY_ENABLED:'true'}})\"",
    "dev:all": "turbo run dev --filter=@trimma/web",
    "build": "turbo run build --filter=@trimma/web...",
    "start": "npm run start --workspace=@trimma/web",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "generate:booking-guides": "node apps/web/scripts/generate-booking-guide-docx.mjs",
    "generate:booking-guides:upload": "node apps/web/scripts/generate-booking-guide-docx.mjs --upload",
    "generate:portal-guides": "node apps/web/scripts/generate-portal-guide-docx.mjs",
    "generate:salon-owner-guides": "node apps/web/scripts/generate-salon-owner-guide-docx.mjs"
  },
  "devDependencies": {
    "puppeteer": "^25.1.0",
    "turbo": "latest"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "pg": "^8.21.0"
  }
}
