# Stripe payments — set in Vercel / local .env (never commit real keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_SANDBOX=
STRIPE_SECRET_KEY_SANDBOX=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_LIVE=
STRIPE_SECRET_KEY_LIVE=
# Optional sandbox fallbacks:
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=

RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@trimma.io
RESEND_FROM_NAME=Trimma
# Public app URL — used for invite links, emails, WhatsApp, and OAuth redirects.
# Local development:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (trimma.io):
NEXT_PUBLIC_APP_URL=https://www.trimma.io
# Beta badge appears automatically on beta.trimma.io only — never on www.trimma.io.

# Upstash Redis — distributed rate limits (checkout, email, password reset). Optional locally (falls back to in-memory).
# Create a free database at https://console.upstash.com and add the REST URL + token to Vercel (live + beta).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Meta WhatsApp Cloud API — Phone Number ID (App ID) from Developer Console → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=1130184513519892
WHATSAPP_ACCESS_TOKEN=

# Meta Facebook Pages API — for /dashboard/social Page posting
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Meta Facebook Login for Business — Configuration ID (required for Business apps; replaces scope)
# FACEBOOK_LOGIN_CONFIG_ID=
# Optional override for page token lookup (Meta default shown)
# FACEBOOK_ME_ACCOUNTS_URL=https://graph.facebook.com/v19.0/me/accounts
