# Stripe payments — set in Vercel / local .env (never commit real keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_SANDBOX=
STRIPE_SECRET_KEY_SANDBOX=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_LIVE=
STRIPE_SECRET_KEY_LIVE=
# Optional sandbox fallbacks:
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=

RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@trimma.io
RESEND_FROM_NAME=Trimma
# Public app URL — used for invite links, emails, WhatsApp, and OAuth redirects.
# Local development:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (trimma.io):
NEXT_PUBLIC_APP_URL=https://www.trimma.io
# Meta WhatsApp Cloud API — Phone Number ID (App ID) from Developer Console → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=1130184513519892
WHATSAPP_ACCESS_TOKEN=

# Meta Facebook Pages API — for /dashboard/social Page posting
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Optional override (defaults to NEXT_PUBLIC_APP_URL/api/facebook/callback)
# FACEBOOK_REDIRECT_URI=https://www.trimma.io/api/facebook/callback
