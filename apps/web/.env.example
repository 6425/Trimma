# Resend transactional email — https://resend.com/docs/send-with-nextjs
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@trimma.io
RESEND_FROM_NAME=Trimma
# Public app URL — used for invite links, emails, WhatsApp, and OAuth redirects.
# Local development:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (trimma.io):
NEXT_PUBLIC_APP_URL=https://www.trimma.io
# Max emails per IP+user within the window (default 10 / 15 min)
EMAIL_RATE_LIMIT_MAX=10
EMAIL_RATE_LIMIT_WINDOW_MS=900000
